// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: journal_entries
// Document ID: {entryId}
// Fields:
//   - title: string (required)
//   - content: string (required)
//   - mood: string (enum: great, good, neutral, low, bad)
//   - tags: list (strings)
//   - is_draft: bool
//   - word_count: number
//   - authorId: string (required, immutable)
//   - createdAt: timestamp (required, immutable)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "mojapelot2@gmail.com" && request.auth.token.email_verified == true);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidJournalEntry(data) {
      return hasRequiredFields(['title', 'content', 'authorId', 'createdAt']) &&
             hasOnlyAllowedFields(['title', 'content', 'mood', 'tags', 'is_draft', 'word_count', 'authorId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() < 10000 &&
             (data.mood == null || data.mood in ['great', 'good', 'neutral', 'low', 'bad']) &&
             (data.tags == null || data.tags is list) &&
             (data.is_draft == null || data.is_draft is bool) &&
             (data.word_count == null || data.word_count is number) &&
             data.authorId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /journal_entries/{entryId} {
      allow read: if isOwner(resource.data.authorId) || isAdmin();
      allow create: if isAuthenticated() && isValidJournalEntry(request.resource.data);
      allow update: if isOwner(resource.data.authorId) && 
                      isValidJournalEntry(request.resource.data) &&
                      request.resource.data.authorId == resource.data.authorId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
